+def _parse_function_node(node, rel_path: str, lines: List[str]) -> FunctionRecord:
+    start = max(node.lineno - 1, 0)
+    end = getattr(node, "end_lineno", start + 1)
+    code = "\n".join(lines[start:end])
+    code_hash = hashlib.md5(code.encode()).hexdigest()
+
+    params = [a.arg for a in node.args.args if a.arg != "self"]
+    ret = ast.unparse(node.returns) if node.returns and hasattr(ast, "unparse") else None
+    try:
+        decorators = [ast.unparse(d) for d in getattr(node, "decorator_list", [])]
+    except Exception:
+        decorators = []
+
+    calls = list(set(_extract_calls(node)))
+
+    return FunctionRecord(
+        name=node.name,
+        file_path=rel_path,
+        line_start=node.lineno,
+        line_end=end,
+        size_lines=end - start,
+        parameters=params,
+        return_type=ret,
+        decorators=decorators,
+        docstring=ast.get_docstring(node) or None,
+        calls_to=calls,
+        complexity=_compute_complexity(node),
+        nesting_depth=_compute_nesting_depth(node),
+        code_hash=code_hash,
+        code=code,
+        is_async=isinstance(node, ast.AsyncFunctionDef),
+    )
+
+def _extract_calls(node) -> List[str]:
+    calls = []
+    for child in ast.walk(node):
+        if not isinstance(child, ast.Call):
+            continue
+        if isinstance(child.func, ast.Name):
+            calls.append(child.func.id)
+        elif isinstance(child.func, ast.Attribute):
+            calls.append(child.func.attr)
+    return calls
+
+def _parse_class_node(node, rel_path: str) -> ClassRecord:
+    start = max(node.lineno - 1, 0)
+    end = getattr(node, "end_lineno", start + 1)
+    methods = [
+        n.name for n in ast.walk(node)
+        if isinstance(n, (ast.FunctionDef, ast.AsyncFunctionDef))
+    ]
+    bases = []
+    for b in node.bases:
+        try:
+            bases.append(ast.unparse(b))
+        except Exception:
+            bases.append("?")
+
+    return ClassRecord(
+        name=node.name,
+        file_path=rel_path,
+        line_start=node.lineno,
+        line_end=end,
+        size_lines=end - start,
+        method_count=len(methods),
+        base_classes=bases,
+        docstring=ast.get_docstring(node) or None,
+        methods=methods,
+        has_init="__init__" in methods,
+    )
+
+class CacheManager:
+    """Handles incremental caching to speed up consecutive scans."""
+    def __init__(self, root: Path):
+        self.cache_dir = root / ".xray_cache"
+        self.cache_file = self.cache_dir / "cache.json"
+        self.cache_data = {}
+        self.has_changes = False
+        self._load()
+
+    def _load(self):
+        if self.cache_file.exists():
+            try:
+                with open(self.cache_file, "r", encoding="utf-8") as f:
+                    self.cache_data = json.load(f)
+            except Exception as e:
+                logger.warning(f"Failed to load cache: {e}")
+                self.cache_data = {}
+
+    def save(self):
+        if self.has_changes:
+            self.cache_dir.mkdir(exist_ok=True)
+            try:
+                with open(self.cache_file, "w", encoding="utf-8") as f:
+                    json.dump(self.cache_data, f, indent=2)
+            except Exception as e:
+                logger.warning(f"Failed to save cache: {e}")
+
+    def get_file_hash(self, fpath: Path) -> str:
+        try:
+            return hashlib.md5(fpath.read_bytes()).hexdigest()
+        except Exception:
+            return ""
+
+    def get_cached_records(self, fpath: Path, rel_path: str) -> Tuple[Optional[Tuple[List[FunctionRecord], List[ClassRecord]]], str]:
+        file_hash = self.get_file_hash(fpath)
+        if not file_hash:
+            return None, file_hash
+
+        entry = self.cache_data.get(rel_path)
+        if entry and entry.get("hash") == file_hash:
+            try:
+                funcs = [FunctionRecord(**f) for f in entry.get("functions", [])]
+                clses = [ClassRecord(**c) for c in entry.get("classes", [])]
+                return (funcs, clses), file_hash
+            except Exception:
+                return None, file_hash
+        return None, file_hash
+
+    def update_cache(self, rel_path: str, file_hash: str, functions: List[FunctionRecord], classes: List[ClassRecord]):
+        self.cache_data[rel_path] = {
+            "hash": file_hash,
+            "functions": [asdict(f) for f in functions],
+            "classes": [asdict(c) for c in classes]
+        }
+        self.has_changes = True
+
 
