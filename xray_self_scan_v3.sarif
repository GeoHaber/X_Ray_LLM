{
  "$schema": "https://docs.oasis-open.org/sarif/sarif/v2.1.0/errata01/os/schemas/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "xray-llm",
          "version": "0.3.0",
          "rules": [
            {
              "id": "PY-007",
              "shortDescription": {
                "text": "Direct os.environ[] access crashes on missing key \u2014 use .get() with default"
              },
              "properties": {
                "tags": [
                  "correctness"
                ]
              },
              "help": {
                "text": "Use os.environ.get('KEY', 'default') instead of os.environ['KEY']"
              }
            },
            {
              "id": "SEC-001",
              "shortDescription": {
                "text": "XSS: Template literal injected into innerHTML without sanitization"
              },
              "properties": {
                "tags": [
                  "security"
                ]
              },
              "help": {
                "text": "Wrap all dynamic values with an HTML escape function or use textContent"
              }
            },
            {
              "id": "QUAL-010",
              "shortDescription": {
                "text": "localStorage access without try/catch \u2014 fails in private browsing"
              },
              "properties": {
                "tags": [
                  "maintainability"
                ]
              },
              "help": {
                "text": "Wrap localStorage access in try/catch for Safari private mode compatibility"
              }
            },
            {
              "id": "PY-006",
              "shortDescription": {
                "text": "Global variable mutation \u2014 hard to test and reason about"
              },
              "properties": {
                "tags": [
                  "correctness"
                ]
              },
              "help": {
                "text": "Pass state through function parameters or use a class"
              }
            },
            {
              "id": "PY-001",
              "shortDescription": {
                "text": "Function annotated as -> None but returns a dict"
              },
              "properties": {
                "tags": [
                  "correctness"
                ]
              },
              "help": {
                "text": "Fix the return type annotation to match actual return value"
              }
            },
            {
              "id": "PY-010",
              "shortDescription": {
                "text": "sys.exit() in library code \u2014 kills the entire process, prevents reuse"
              },
              "properties": {
                "tags": [
                  "correctness"
                ]
              },
              "help": {
                "text": "Raise an exception instead; let the caller decide how to handle failure"
              }
            },
            {
              "id": "SEC-003",
              "shortDescription": {
                "text": "Command injection: subprocess called with shell=True"
              },
              "properties": {
                "tags": [
                  "security"
                ]
              },
              "help": {
                "text": "Use shell=False and pass args as a list"
              }
            },
            {
              "id": "SEC-007",
              "shortDescription": {
                "text": "Code injection: eval/exec with potentially untrusted input"
              },
              "properties": {
                "tags": [
                  "security"
                ]
              },
              "help": {
                "text": "Replace eval/exec with safe alternatives (ast.literal_eval, JSON.parse)"
              }
            },
            {
              "id": "SEC-009",
              "shortDescription": {
                "text": "Deserialization attack: unsafe pickle/yaml loading"
              },
              "properties": {
                "tags": [
                  "security"
                ]
              },
              "help": {
                "text": "Use json or yaml.safe_load instead of pickle.loads/yaml.load"
              }
            },
            {
              "id": "QUAL-001",
              "shortDescription": {
                "text": "Bare except clause swallows all errors including KeyboardInterrupt"
              },
              "properties": {
                "tags": [
                  "maintainability"
                ]
              },
              "help": {
                "text": "Catch specific exceptions: except (ValueError, TypeError):"
              }
            },
            {
              "id": "PY-008",
              "shortDescription": {
                "text": "File opened without explicit encoding \u2014 platform-dependent behavior"
              },
              "properties": {
                "tags": [
                  "correctness"
                ]
              },
              "help": {
                "text": "Always specify encoding='utf-8' for text file operations"
              }
            },
            {
              "id": "SEC-004",
              "shortDescription": {
                "text": "SQL injection: String formatting in SQL query"
              },
              "properties": {
                "tags": [
                  "security"
                ]
              },
              "help": {
                "text": "Use parameterized queries with ? or %s placeholders"
              }
            },
            {
              "id": "QUAL-011",
              "shortDescription": {
                "text": "Catching broad Exception \u2014 masks bugs and makes debugging hard"
              },
              "properties": {
                "tags": [
                  "maintainability"
                ]
              },
              "help": {
                "text": "Catch specific exceptions (ValueError, TypeError, OSError) instead of Exception"
              }
            },
            {
              "id": "QUAL-003",
              "shortDescription": {
                "text": "Unchecked int() on user input \u2014 will crash on non-numeric values"
              },
              "properties": {
                "tags": [
                  "maintainability"
                ]
              },
              "help": {
                "text": "Wrap in try/except ValueError with a sensible default"
              }
            },
            {
              "id": "QUAL-004",
              "shortDescription": {
                "text": "Unchecked float() on user input \u2014 will crash on non-numeric values"
              },
              "properties": {
                "tags": [
                  "maintainability"
                ]
              },
              "help": {
                "text": "Wrap in try/except ValueError with a sensible default"
              }
            },
            {
              "id": "PY-005",
              "shortDescription": {
                "text": "JSON parsing without error handling \u2014 crashes on malformed input"
              },
              "properties": {
                "tags": [
                  "correctness"
                ]
              },
              "help": {
                "text": "Wrap json.loads() in try/except json.JSONDecodeError"
              }
            },
            {
              "id": "SEC-005",
              "shortDescription": {
                "text": "SSRF: URL constructed from user input without validation"
              },
              "properties": {
                "tags": [
                  "security"
                ]
              },
              "help": {
                "text": "Validate URLs against an allowlist of trusted hosts before making requests"
              }
            },
            {
              "id": "PORT-001",
              "shortDescription": {
                "text": "Hardcoded user-specific path \u2014 breaks on any other machine"
              },
              "properties": {
                "tags": [
                  "portability"
                ]
              },
              "help": {
                "text": "Replace with Path.home() or os.environ.get('ENV_VAR', fallback). For test fixtures use Path(__file__).resolve().parent / 'subdir'"
              }
            },
            {
              "id": "PORT-002",
              "shortDescription": {
                "text": "Hardcoded C:\\AI\\ path \u2014 not portable; use ZENAI_MODEL_DIR env var or Path.home() / 'AI' fallback"
              },
              "properties": {
                "tags": [
                  "portability"
                ]
              },
              "help": {
                "text": "Use os.environ.get('ZENAI_MODEL_DIR', str(Path.home() / 'AI' / 'Models'))"
              }
            },
            {
              "id": "PORT-003",
              "shortDescription": {
                "text": "Hardcoded absolute Windows path \u2014 not portable to Linux/macOS"
              },
              "properties": {
                "tags": [
                  "portability"
                ]
              },
              "help": {
                "text": "Use Path(__file__).parent-relative paths or environment variables"
              }
            },
            {
              "id": "PORT-004",
              "shortDescription": {
                "text": "Windows-only module import \u2014 will crash on Linux/macOS unless guarded by platform check"
              },
              "properties": {
                "tags": [
                  "portability"
                ]
              },
              "help": {
                "text": "Guard with: if platform.system() == 'Windows': import winreg  or use try/except ImportError"
              }
            },
            {
              "id": "SEC-008",
              "shortDescription": {
                "text": "Hardcoded secret: credential embedded in source code"
              },
              "properties": {
                "tags": [
                  "security"
                ]
              },
              "help": {
                "text": "Move secrets to environment variables or a secrets manager"
              }
            },
            {
              "id": "SEC-006",
              "shortDescription": {
                "text": "CORS misconfiguration: wildcard origin allows any site"
              },
              "properties": {
                "tags": [
                  "security"
                ]
              },
              "help": {
                "text": "Restrict CORS to specific trusted origins (e.g., localhost)"
              }
            },
            {
              "id": "SEC-010",
              "shortDescription": {
                "text": "Path traversal: user input may escape intended directory"
              },
              "properties": {
                "tags": [
                  "security"
                ]
              },
              "help": {
                "text": "Validate and normalize paths, reject '..' components"
              }
            },
            {
              "id": "QUAL-006",
              "shortDescription": {
                "text": "Non-daemon thread may prevent clean shutdown"
              },
              "properties": {
                "tags": [
                  "maintainability"
                ]
              },
              "help": {
                "text": "Set daemon=True for background worker threads"
              }
            },
            {
              "id": "QUAL-008",
              "shortDescription": {
                "text": "Long sleep (10+ seconds) in code \u2014 may indicate polling instead of events"
              },
              "properties": {
                "tags": [
                  "maintainability"
                ]
              },
              "help": {
                "text": "Use threading.Event, asyncio, or callback patterns instead of long sleeps"
              }
            },
            {
              "id": "QUAL-009",
              "shortDescription": {
                "text": "Explicit keep-alive header \u2014 may cause connection hang in some HTTP servers"
              },
              "properties": {
                "tags": [
                  "maintainability"
                ]
              },
              "help": {
                "text": "Remove Connection: keep-alive header; let the server/framework handle it"
              }
            },
            {
              "id": "PY-003",
              "shortDescription": {
                "text": "Wildcard import pollutes namespace and hides dependencies"
              },
              "properties": {
                "tags": [
                  "correctness"
                ]
              },
              "help": {
                "text": "Import specific names: from module import func1, func2"
              }
            }
          ]
        }
      },
      "results": [
