#!/usr/bin/env python3
"""
Pre-commit hook: Run X-Ray self-scan before commit.
Install: cp .githooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
"""

import subprocess
import sys
from pathlib import Path


def run_xray_check():
    """Run X-Ray smell detection on staged files."""
    print("🔍 Running X-Ray code smell check...")
    
    # Get current branch/directory
    repo_root = Path.cwd()
    
    # Run X-Ray scan
    result = subprocess.run(
        [sys.executable, "x_ray_claude.py", "--smell", "--path", str(repo_root)],
        capture_output=True,
        text=True,
        cwd=repo_root
    )
    
    print(result.stdout)
    
    if result.returncode != 0:
        print("⚠️  X-Ray check failed. Review the output above.")
        print("To skip: git commit --no-verify")
        return False
    
    return True


if __name__ == "__main__":
    if not run_xray_check():
        sys.exit(1)
    sys.exit(0)
